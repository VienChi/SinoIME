          "stringUnit": {
            "state": "translated",
            "value": "有新版本"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "有新版本"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã có bản cập nhật mới"
          }
        }
      }
    },
