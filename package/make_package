#!/bin/bash

set -e

DERIVED_DATA_PATH=$1
BUNDLE_IDENTIFIER='org.hannom.inputmethod.SinoIME'
INSTALL_LOCATION='/Library/Input Methods'

cd "$(dirname $0)"
source common.sh

pkgbuild \
    --root "${PROJECT_ROOT}/${DERIVED_DATA_PATH}/Build/Products/Release" \
    --filter '.*\.swiftmodule$' \
    --component-plist SinoIME-component.plist \
    --identifier "${BUNDLE_IDENTIFIER}" \
    --version "$(get_app_version)" \
    --install-location "${INSTALL_LOCATION}" \
    --scripts "${PROJECT_ROOT}/scripts" \
    SinoIME-component.pkg

sed "s/@VERSION@/$(get_app_version)/" Distribution > Distribution-versioned.xml

productbuild \
    --distribution Distribution-versioned.xml \
    --package-path . \
    --resources . \
    SinoIME.pkg

rm Distribution-versioned.xml

rm SinoIME-component.pkg
